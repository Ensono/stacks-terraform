{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "YAMLLint",
      "type": "shell",
      "command": "yamllint",
      "args": [
        "."
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "owner": "yaml",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": [
          {
            "regexp": "^(\\./.+)$",
            "file": 1
          },
          {
            "regexp": "^\\s+(\\d+):(\\d+)\\s+(error|warning)\\s+(.+)$",
            "line": 1,
            "column": 2,
            "severity": 3,
            "message": 4
          }
        ]
      }
    }
  ]
}
